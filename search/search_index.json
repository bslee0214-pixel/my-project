{"config":{"lang":["ko","en"],"separator":"[\\s\\-]+","pipeline":[" "],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"\ub0b4 \uae30\uc220 \ub178\ud2b8","text":"<p>\uac1c\ubc1c\ud558\uba74\uc11c \ubc30\uc6b0\uace0 \uae30\ub85d\ud55c \ub0b4\uc6a9\uc744 \uc815\ub9ac\ud558\ub294 \uac1c\uc778 \uae30\uc220 \ubb38\uc11c \uc0ac\uc774\ud2b8\uc785\ub2c8\ub2e4.</p>"},{"location":"#_2","title":"\uc18c\uac1c","text":"<p>\uc774 \uc0ac\uc774\ud2b8\ub294 \ub2e4\uc74c\uacfc \uac19\uc740 \ub0b4\uc6a9\uc744 \uae30\ub85d\ud558\uae30 \uc704\ud574 \ub9cc\ub4e4\uc5b4\uc84c\uc2b5\ub2c8\ub2e4.</p> <ul> <li>\uac1c\ubc1c \ud559\uc2b5 \ub0b4\uc6a9 \uc815\ub9ac</li> <li>\uc2e4\ubb34 \ud301 \uae30\ub85d</li> <li>\uc0c8\ub85c\uc6b4 \uae30\uc220 \uc2e4\ud5d8 \uba54\ubaa8</li> <li>\ubb38\uc81c \ud574\uacb0 \uacfc\uc815 \uc544\uce74\uc774\ube59</li> </ul> <p>\uafb8\uc900\ud788 \ubb38\uc11c\ub97c \ucd94\uac00\ud558\uba74\uc11c \ub098\ub9cc\uc758 \uac1c\ubc1c \uc704\ud0a4\ucc98\ub7fc \uc6b4\uc601\ud560 \uc608\uc815\uc785\ub2c8\ub2e4.</p>"},{"location":"#_3","title":"\ubaa9\ucc28","text":"<ul> <li>\uc2dc\uc791 \uac00\uc774\ub4dc</li> <li>\uac1c\ubc1c \uba54\ubaa8</li> <li>\uc2e4\ud5d8 \uae30\ub85d</li> <li>\uc720\uc6a9\ud55c \ub9c1\ud06c</li> </ul>"},{"location":"#_4","title":"\ud658\uc601\ud569\ub2c8\ub2e4 \ud83d\udc4b","text":"<p>\ubc29\ubb38\ud574\uc8fc\uc154\uc11c \uac10\uc0ac\ud569\ub2c8\ub2e4.</p> <p>\uc774 \uacf5\uac04\uc740 MkDocs Material \ud14c\ub9c8\ub97c \uae30\ubc18\uc73c\ub85c \ub9cc\ub4e4\uc5b4\uc84c\uc73c\uba70, Markdown\uc73c\ub85c \uc27d\uace0 \ube60\ub974\uac8c \ubb38\uc11c\ub97c \uad00\ub9ac\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <p>\uc55e\uc73c\ub85c \ub2e4\uc591\ud55c \uac1c\ubc1c \uae30\ub85d\ub4e4\uc744 \uacc4\uc18d \ucd94\uac00\ud574\ub098\uac08 \uc608\uc815\uc785\ub2c8\ub2e4.</p>"},{"location":"guides/getting-started/","title":"MkDocs \uc2dc\uc791\ud558\uae30","text":"<p>MkDocs\uc640 Material \ud14c\ub9c8\ub97c \uc0ac\uc6a9\ud574 \uae30\uc220 \ubb38\uc11c \uc0ac\uc774\ud2b8\ub97c \ub9cc\ub4dc\ub294 \ubc29\ubc95\uc744 \uac04\ub2e8\ud788 \uc815\ub9ac\ud55c \uac00\uc774\ub4dc\uc785\ub2c8\ub2e4.</p>"},{"location":"guides/getting-started/#_1","title":"\uc18c\uac1c","text":"<p>MkDocs\ub294 Markdown \uae30\ubc18\uc758 \uc815\uc801 \ubb38\uc11c \uc0ac\uc774\ud2b8 \uc0dd\uc131\uae30\uc785\ub2c8\ub2e4.</p> <p>\ud2b9\ud788 Material \ud14c\ub9c8\ub97c \uc0ac\uc6a9\ud558\uba74 \ub2e4\uc74c\uacfc \uac19\uc740 \uae30\ub2a5\uc744 \uc27d\uac8c \uc0ac\uc6a9\ud560 \uc218 \uc788\uc2b5\ub2c8\ub2e4.</p> <ul> <li>\ub2e4\ud06c \ubaa8\ub4dc</li> <li>\uac80\uc0c9 \uae30\ub2a5</li> <li>\ucf54\ub4dc \ud558\uc774\ub77c\uc774\ud305</li> <li>\ud0ed \ub124\ube44\uac8c\uc774\uc158</li> <li>\ubc18\uc751\ud615 UI</li> </ul>"},{"location":"guides/getting-started/#_2","title":"\ubaa9\ucc28","text":"<ol> <li>MkDocs \uc124\uce58</li> <li>\ud504\ub85c\uc81d\ud2b8 \uc0dd\uc131</li> <li>Material \ud14c\ub9c8 \uc801\uc6a9</li> <li>\ub85c\uceec \uc11c\ubc84 \uc2e4\ud589</li> <li>\ube4c\ub4dc \ubc0f \ubc30\ud3ec</li> </ol>"},{"location":"guides/getting-started/#1-mkdocs","title":"1. MkDocs \uc124\uce58","text":"<pre><code>pip install mkdocs-material\n</code></pre>"},{"location":"guides/getting-started/#2","title":"2. \ud504\ub85c\uc81d\ud2b8 \uc0dd\uc131","text":"<pre><code>mkdocs new my-docs\ncd my-docs\n</code></pre>"},{"location":"guides/getting-started/#3-material","title":"3. Material \ud14c\ub9c8 \uc801\uc6a9","text":"<p><code>mkdocs.yml</code> \ud30c\uc77c \uc218\uc815:</p> <pre><code>theme:\n  name: material\n</code></pre>"},{"location":"guides/getting-started/#4","title":"4. \ub85c\uceec \uc11c\ubc84 \uc2e4\ud589","text":"<pre><code>mkdocs serve\n</code></pre> <p>\ube0c\ub77c\uc6b0\uc800\uc5d0\uc11c \uc544\ub798 \uc8fc\uc18c \uc811\uc18d:</p> <pre><code>http://127.0.0.1:8000\n</code></pre>"},{"location":"guides/getting-started/#5","title":"5. \uc0ac\uc774\ud2b8 \ube4c\ub4dc","text":"<pre><code>mkdocs build\n</code></pre> <p>\ube4c\ub4dc \uacb0\uacfc\ub294 <code>site/</code> \ud3f4\ub354\uc5d0 \uc0dd\uc131\ub429\ub2c8\ub2e4.</p>"},{"location":"guides/getting-started/#_3","title":"\ub9c8\ubb34\ub9ac","text":"<p>MkDocs\ub294 \uc124\uc815\uc774 \uac04\ub2e8\ud558\uace0 Markdown \uae30\ubc18\uc774\ub77c\uc11c \uac1c\uc778 \uae30\uc220 \ubb38\uc11c \uad00\ub9ac\uc5d0 \ub9e4\uc6b0 \ud3b8\ub9ac\ud569\ub2c8\ub2e4.</p> <p>\uc791\uc740 \uba54\ubaa8\ubd80\ud130 \uc2dc\uc791\ud574\uc11c \uc810\uc810 \ubb38\uc11c\ub97c \ud655\uc7a5\ud574\ubcf4\uc138\uc694.</p>"},{"location":"notes/first-note/","title":"\ubc14\uc774\ube0c \ucf54\ub529 \uba54\ubaa8","text":"<p>\uc624\ub298 \ubc30\uc6b4 \ubc14\uc774\ube0c \ucf54\ub529(Vibe Coding)\uc5d0 \ub300\ud55c \uac04\ub2e8\ud55c \uae30\ub85d\uc785\ub2c8\ub2e4.</p>"},{"location":"notes/first-note/#_2","title":"\uc18c\uac1c","text":"<p>\uc624\ub298\uc740 AI\uc640 \ud568\uaed8 \uac1c\ubc1c\ud558\ub294 \ubc29\uc2dd\uc778 \"\ubc14\uc774\ube0c \ucf54\ub529\"\uc5d0 \ub300\ud574 \uacf5\ubd80\ud588\ub2e4.</p> <p>\uae30\uc874\ucc98\ub7fc \ubaa8\ub4e0 \ucf54\ub4dc\ub97c \uc9c1\uc811 \uc791\uc131\ud558\ub294 \ubc29\uc2dd\uc774 \uc544\ub2c8\ub77c, \uc544\uc774\ub514\uc5b4\uc640 \uc758\ub3c4\ub97c \uc124\uba85\ud558\uba74\uc11c AI\uc640 \ud611\uc5c5\ud558\ub294 \ud615\ud0dc\uac00 \uc778\uc0c1\uc801\uc774\uc5c8\ub2e4.</p>"},{"location":"notes/first-note/#_3","title":"\ubaa9\ucc28","text":"<ol> <li>\ubc14\uc774\ube0c \ucf54\ub529\uc774\ub780?</li> <li>\ub290\ub080 \uc810</li> <li>\uc7a5\uc810</li> <li>\uc55e\uc73c\ub85c \ud574\ubcfc \uac83</li> </ol>"},{"location":"notes/first-note/#1","title":"1. \ubc14\uc774\ube0c \ucf54\ub529\uc774\ub780?","text":"<p>\ubc14\uc774\ube0c \ucf54\ub529\uc740 AI\uc5d0\uac8c \ub2e4\uc74c\uacfc \uac19\uc740 \ub0b4\uc6a9\uc744 \uc124\uba85\ud558\uba70 \uac1c\ubc1c\ud558\ub294 \ubc29\uc2dd\uc774\ub2e4.</p> <ul> <li>\uc6d0\ud558\ub294 \uae30\ub2a5</li> <li>\ud654\uba74 \uad6c\uc870</li> <li>\ub3d9\uc791 \ubc29\uc2dd</li> <li>\ucf54\ub4dc \uc218\uc815 \ubc29\ud5a5</li> </ul> <p>AI\ub294 \uc774\ub97c \ubc14\ud0d5\uc73c\ub85c \ucf54\ub4dc \ucd08\uc548\uc744 \uc0dd\uc131\ud574\uc900\ub2e4.</p>"},{"location":"notes/first-note/#2","title":"2. \ub290\ub080 \uc810","text":"<p>\uc0dd\uc0b0\uc131\uc774 \ub9e4\uc6b0 \ube60\ub974\ub2e4\ub294 \uc810\uc774 \uac00\uc7a5 \uc778\uc0c1\uc801\uc774\uc5c8\ub2e4.</p> <p>\ud2b9\ud788 \ubc18\ubcf5\uc801\uc778 \ucf54\ub4dc \uc791\uc131\uc774\ub098 \uae30\ubcf8 \uad6c\uc870 \uc0dd\uc131 \uc18d\ub3c4\uac00 \uad49\uc7a5\ud788 \ube68\ub790\ub2e4.</p> <p>\ub2e4\ub9cc \uc644\uc804 \uc790\ub3d9\uc774\ub77c\uae30\ubcf4\ub2e4\ub294 \"AI\uc640 \ud568\uaed8 \uac1c\ubc1c\ud55c\ub2e4\"\ub294 \ub290\ub08c\uc5d0 \uac00\uae4c\uc6e0\ub2e4.</p>"},{"location":"notes/first-note/#3","title":"3. \uc7a5\uc810","text":"<ul> <li>\ube60\ub978 \ud504\ub85c\ud1a0\ud0c0\uc774\ud551</li> <li>\ubc18\ubcf5 \uc791\uc5c5 \uac10\uc18c</li> <li>\uc544\uc774\ub514\uc5b4 \uad6c\ud604 \uc18d\ub3c4 \ud5a5\uc0c1</li> <li>\uc0c8\ub85c\uc6b4 \uae30\uc220 \ud559\uc2b5 \ubcf4\uc870</li> </ul>"},{"location":"notes/first-note/#4","title":"4. \uc55e\uc73c\ub85c \ud574\ubcfc \uac83","text":"<p>\uc55e\uc73c\ub85c \uc544\ub798\uc640 \uac19\uc740 \uc791\uc5c5\uc5d0 \ud65c\uc6a9\ud574\ubcfc \uacc4\ud68d\uc774\ub2e4.</p> <ul> <li>WinUI \uc571 \uac1c\ubc1c</li> <li>\uc790\ub3d9\ud654 \ub3c4\uad6c \uc81c\uc791</li> <li>\uac8c\uc784 \ubcf4\uc870 \uc571 \uc2e4\ud5d8</li> <li>\ubb38\uc11c \uc790\ub3d9 \uc0dd\uc131</li> </ul>"},{"location":"notes/first-note/#_4","title":"\ub9c8\ubb34\ub9ac","text":"<p>AI \uc2dc\ub300\uc5d0\ub294 \ucf54\ub4dc\ub97c \ub9ce\uc774 \uc544\ub294 \uac83\ub3c4 \uc911\uc694\ud558\uc9c0\ub9cc, \uc6d0\ud558\ub294 \uacb0\uacfc\ub97c \uc798 \uc124\uba85\ud558\ub294 \ub2a5\ub825\ub3c4 \uc810\uc810 \uc911\uc694\ud574\uc9c0\ub294 \uac83 \uac19\ub2e4.</p>"},{"location":"notes/python-basics/","title":"Python \uae30\ucd08 \ubb38\ubc95 \uc815\ub9ac","text":"<p>Python\uc744 \ucc98\uc74c \uc2dc\uc791\ud560 \ub54c \uc54c\uc544\ub450\uba74 \uc88b\uc740 \ud575\uc2ec \ubb38\ubc95\ub4e4\uc744 \uac04\ub2e8\ud788 \uc815\ub9ac\ud55c \ubb38\uc11c\uc785\ub2c8\ub2e4.</p>"},{"location":"notes/python-basics/#_1","title":"\uc18c\uac1c","text":"<p>Python\uc740 \ubb38\ubc95\uc774 \uac04\uacb0\ud558\uace0 \uc77d\uae30 \uc26c\uc6cc\uc11c \uc785\ubb38\uc6a9 \ud504\ub85c\uadf8\ub798\ubc0d \uc5b8\uc5b4\ub85c \ub9ce\uc774 \uc0ac\uc6a9\ub429\ub2c8\ub2e4.</p> <p>\uc774 \ubb38\uc11c\uc5d0\uc11c\ub294 \ub2e4\uc74c \ub0b4\uc6a9\uc744 \ub2e4\ub8f9\ub2c8\ub2e4.</p> <ul> <li>\ubcc0\uc218</li> <li>\uc870\uac74\ubb38</li> <li>\ubc18\ubcf5\ubb38</li> <li>\ud568\uc218 \uae30\ucd08</li> </ul>"},{"location":"notes/python-basics/#_2","title":"\ubaa9\ucc28","text":"<ol> <li>\ubcc0\uc218</li> <li>\uc870\uac74\ubb38</li> <li>\ubc18\ubcf5\ubb38</li> <li>\ud568\uc218 \uae30\ucd08</li> <li>\ub9c8\ubb34\ub9ac</li> </ol>"},{"location":"notes/python-basics/#1","title":"1. \ubcc0\uc218","text":"<p>\ubcc0\uc218\ub294 \ub370\uc774\ud130\ub97c \uc800\uc7a5\ud558\ub294 \uacf5\uac04\uc785\ub2c8\ub2e4.</p>"},{"location":"notes/python-basics/#_3","title":"\ubb38\uc790\uc5f4 \ubcc0\uc218","text":"<pre><code>name = \"Python\"\nprint(name)\n</code></pre>"},{"location":"notes/python-basics/#_4","title":"\uc22b\uc790 \ubcc0\uc218","text":"<pre><code>age = 20\nheight = 175.5\n\nprint(age)\nprint(height)\n</code></pre>"},{"location":"notes/python-basics/#_5","title":"\uc5ec\ub7ec \ubcc0\uc218 \uc0ac\uc6a9","text":"<pre><code>x = 10\ny = 20\n\nprint(x + y)\n</code></pre>"},{"location":"notes/python-basics/#2","title":"2. \uc870\uac74\ubb38","text":"<p>\uc870\uac74\ubb38\uc740 \ud2b9\uc815 \uc870\uac74\uc5d0 \ub530\ub77c \ucf54\ub4dc\ub97c \uc2e4\ud589\ud569\ub2c8\ub2e4.</p>"},{"location":"notes/python-basics/#if","title":"if \ubb38","text":"<pre><code>age = 18\n\nif age &gt;= 18:\n    print(\"\uc131\uc778\uc785\ub2c8\ub2e4.\")\n</code></pre>"},{"location":"notes/python-basics/#if-else","title":"if ~ else \ubb38","text":"<pre><code>age = 15\n\nif age &gt;= 18:\n    print(\"\uc131\uc778\uc785\ub2c8\ub2e4.\")\nelse:\n    print(\"\ubbf8\uc131\ub144\uc790\uc785\ub2c8\ub2e4.\")\n</code></pre>"},{"location":"notes/python-basics/#elif","title":"elif \uc0ac\uc6a9","text":"<pre><code>score = 85\n\nif score &gt;= 90:\n    print(\"A\")\nelif score &gt;= 80:\n    print(\"B\")\nelse:\n    print(\"C\")\n</code></pre>"},{"location":"notes/python-basics/#3","title":"3. \ubc18\ubcf5\ubb38","text":"<p>\ubc18\ubcf5\ubb38\uc740 \uac19\uc740 \uc791\uc5c5\uc744 \uc5ec\ub7ec \ubc88 \uc218\ud589\ud560 \ub54c \uc0ac\uc6a9\ud569\ub2c8\ub2e4.</p>"},{"location":"notes/python-basics/#for","title":"for \ubb38","text":"<pre><code>for i in range(5):\n    print(i)\n</code></pre> <p>\ucd9c\ub825 \uacb0\uacfc:</p> <pre><code>0\n1\n2\n3\n4\n</code></pre>"},{"location":"notes/python-basics/#_6","title":"\ub9ac\uc2a4\ud2b8 \ubc18\ubcf5","text":"<pre><code>fruits = [\"apple\", \"banana\", \"orange\"]\n\nfor fruit in fruits:\n    print(fruit)\n</code></pre>"},{"location":"notes/python-basics/#while","title":"while \ubb38","text":"<pre><code>count = 0\n\nwhile count &lt; 5:\n    print(count)\n    count += 1\n</code></pre>"},{"location":"notes/python-basics/#4","title":"4. \ud568\uc218 \uae30\ucd08","text":"<p>\ud568\uc218\ub294 \ubc18\ubcf5\ud574\uc11c \uc0ac\uc6a9\ud558\ub294 \ucf54\ub4dc\ub97c \ubb36\ub294 \uae30\ub2a5\uc785\ub2c8\ub2e4.</p>"},{"location":"notes/python-basics/#_7","title":"\ud568\uc218 \uc815\uc758","text":"<pre><code>def hello():\n    print(\"Hello Python\")\n</code></pre>"},{"location":"notes/python-basics/#_8","title":"\ud568\uc218 \ud638\ucd9c","text":"<pre><code>hello()\n</code></pre>"},{"location":"notes/python-basics/#_9","title":"\ub9e4\uac1c\ubcc0\uc218 \uc0ac\uc6a9","text":"<pre><code>def greet(name):\n    print(\"\uc548\ub155\ud558\uc138\uc694,\", name)\n</code></pre> <p>\ud638\ucd9c:</p> <pre><code>greet(\"\ubc24\ud1a8\")\n</code></pre>"},{"location":"notes/python-basics/#_10","title":"\ubc18\ud658\uac12 \uc0ac\uc6a9","text":"<pre><code>def add(a, b):\n    return a + b\n\nresult = add(10, 20)\n\nprint(result)\n</code></pre>"},{"location":"notes/python-basics/#5","title":"5. \ub9c8\ubb34\ub9ac","text":"<p>\uc774\ubc88 \ubb38\uc11c\uc5d0\uc11c\ub294 Python\uc758 \uac00\uc7a5 \uae30\ubcf8\uc801\uc778 \ubb38\ubc95\ub4e4\uc744 \uc815\ub9ac\ud588\uc2b5\ub2c8\ub2e4.</p> <p>Python\uc740 \uae30\ucd08 \ubb38\ubc95\uc774 \ub2e8\uc21c\ud558\uace0 \uc9c1\uad00\uc801\uc774\ub77c \uc790\ub3d9\ud654, \ub370\uc774\ud130 \ubd84\uc11d, AI, \uc6f9 \uac1c\ubc1c \ub4f1 \ub2e4\uc591\ud55c \ubd84\uc57c\uc5d0\uc11c \ud65c\uc6a9\ub429\ub2c8\ub2e4.</p> <p>\ub2e4\uc74c \ub2e8\uacc4\uc5d0\uc11c\ub294 \uc544\ub798 \ub0b4\uc6a9\uc744 \uacf5\ubd80\ud574\ubcf4\uba74 \uc88b\uc2b5\ub2c8\ub2e4.</p> <ul> <li>\ub9ac\uc2a4\ud2b8\uc640 \ub515\uc154\ub108\ub9ac</li> <li>\ud074\ub798\uc2a4</li> <li>\ud30c\uc77c \uc785\ucd9c\ub825</li> <li>\uc608\uc678 \ucc98\ub9ac</li> <li>\ubaa8\ub4c8 \uc0ac\uc6a9\ubc95</li> </ul> <p>\uafb8\uc900\ud788 \uc9c1\uc811 \ucf54\ub4dc\ub97c \uc791\uc131\ud574\ubcf4\ub294 \uac83\uc774 \uac00\uc7a5 \uc911\uc694\ud569\ub2c8\ub2e4 \ud83d\ude80</p>"}]}